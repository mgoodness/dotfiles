# vim: set ft=gitconfig

# Ref: https://dandavison.github.io/delta/get-started.html
# Ref: https://dandavison.github.io/delta/configuration.html

[branch]
	autoSetupRebase = always	# rebase (not merge) when pulling for all new branches
[color]
	ui = true
[commit]
	gpgSign = true
[core]
	autocrlf = input	# normalize line endings on commit (but not checkout)
	editor = "zed-preview --wait"
	excludesFile = ~/.config/git/ignore
	pager = command -v delta >/dev/null 2>&1 && delta || ${PAGER:-less}
	trustctime = false	# don't trust ctime for file-change detection; unreliable on network/virtual filesystems
[credential]
	helper = osxkeychain
[delta]
	hyperlinks = true	# make file paths clickable in supported terminals
	navigate = true		# enable n/N to jump between diff hunks
[diff]
	colorMoved = default	# color moved lines differently
	noprefix = true		# strip a/ b/ path prefixes from diff output
[fetch]
	prune = true		# prune deleted remote refs
	pruneTags = true	# prune deleted remote tags
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[include]
	path = ~/.config/delta/catppuccin-frappe.gitconfig
[includeIf "gitdir:~/Code/emu.github.com/"]
	path = ~/Code/emu.github.com/.gitconfig
[includeIf "gitdir:~/Code/github.com/"]
	path = ~/Code/github.com/.gitconfig
[includeIf "gitdir:~/Code/github.mlbam.net/"]
	path = ~/Code/github.mlbam.net/.gitconfig
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[log]
	date = relative		# show "3 days ago" instead of a timestamp
	follow = true		# track renames in git log -- <file>
[merge]
	autoStash = true	# stash/restore dirty worktree automatically
	conflictstyle = diff3	# show common ancestor in conflict markers (3-way view)
[pull]
	# ff only fires with --no-rebase; rebase = merges takes precedence during normal pulls
	# ff = only		    # abort if pull can't fast-forward
	rebase = merges		# rebase on pull, preserving merge commits
[push]
	autoSetupRemote = true	# auto-create remote tracking branch on first push
	default = upstream	# push to upstream even if branch names differ
	followTags = true	# always push annotated tag(s)
[rebase]
	autoSquash = true	# auto-apply fixup!/squash! commits during interactive rebase
	autoStash = true	# stash/restore dirty worktree automatically
	updateRefs = true	# when rebasing, move any branch ref that points to a rebased commit
[tag]
	forceSignAnnotated = true	# sign all annotated tags
