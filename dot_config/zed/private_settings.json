{
  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "tree_view": true
  },
  "file_types": {
    "Git Config": ["*gitconfig"]
  },
  "languages": {
    "Git Config": {
      "hard_tabs": true,
      "tab_size": 8
    }
  },
  "cli_default_open_behavior": "existing_window",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "ui_font_family": ".SystemUIFont",
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "plan"
      },
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "zed"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "base_keymap": "VSCode",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "terminal": {
    "working_directory": "current_file_directory",
    "copy_on_select": true,
    "font_family": "FiraCode Nerd Font Mono"
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "format": {
            "singleQuote": false
          }
        }
      }
    }
  }
}
