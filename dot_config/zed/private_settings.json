{
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev"
    },
    "default_profile": "write",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "plan"
      },
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 16,
  "cli_default_open_behavior": "existing_window",
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "edit_predictions": {
    "allow_data_collection": "yes",
    "provider": "zed"
  },
  "file_types": {
    "Git Config": ["*gitconfig"]
  },
  "icon_theme": {
    "dark": "Catppuccin Frappé",
    "light": "Catppuccin Latte",
    "mode": "system"
  },
  "git_panel": {
    "tree_view": true
  },
  "languages": {
    "Git Config": {
      "hard_tabs": true,
      "tab_size": 8
    }
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "format": {
            "singleQuote": false
          }
        }
      }
    }
  },
  "tabs": {
    "file_icons": true
  },
  "terminal": {
    "copy_on_select": true,
    "font_family": "FiraCode Nerd Font Mono",
    "working_directory": "current_file_directory"
  },
  "theme": {
    "dark": "Catppuccin Frappé",
    "light": "Catppuccin Latte",
    "mode": "system"
  },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "vim_mode": true
}
