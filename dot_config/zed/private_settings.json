// Ref: https://codeberg.org/jsu/dotfiles/src/branch/main/zed/settings.json
{
  "agent": {
    "commit_message_instructions": "Use the Conventional Commits format: <type>(<scope>): <description>.",
    "commit_message_model": { "model": "claude-4-5-haiku", "provider": "copilot" },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat"
    },
    "default_profile": "write",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": { "default_config_options": { "mode": "plan" }, "type": "registry" }
  },
  "autosave": { "after_delay": { "milliseconds": 500 } },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "csv": true,
    "dart": true,
    "dependi": true,
    "dockerfile": true,
    "editorconfig": true,
    "fish": true,
    "ghostty": true,
    "git-firefly": true,
    "github-actions": true,
    "golangci-lint": true,
    "helm": true,
    "html": true,
    "ini": true,
    "log": true,
    "lua": true,
    "make": true,
    "mcp-server-context7": true,
    "python-requirements": true,
    "ruby": true,
    "scheme": true,
    "ssh-config": true,
    "terraform": true,
    "tombi": true,
    "toml": true,
    "xml": true
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true,
    "ss10": true,
    "cv62": true // @_ ligature
  },
  "buffer_font_size": 16,
  "cli_default_open_behavior": "existing_window",
  "code_lens": "on",
  "colorize_brackets": true,
  "completion_menu_item_kind": "symbol",
  "context_servers": {
    "atlassian-rovo": {
      "enabled": true,
      "remote": false,
      "settings": {
        "endpoint": "https://mcp.atlassian.com/v1/mcp/authv2",
        "proxy_package": "mcp-remote@0.1.37"
      }
    },
    "mcp-server-context7": { "enabled": true, "remote": false, "settings": {} }
  },
  "document_folding_ranges": "on",
  "edit_predictions": { "allow_data_collection": "yes", "provider": "copilot" },
  "excerpt_context_lines": 4,
  "file_finder": { "include_ignored": "all" },
  "file_types": {
    "Ghostty": ["**/com.mitchellh.ghostty/config", "**/ghostty/config", "**/ghostty/themes/*"],
    "Git Attributes": ["**/{.git,.git/info,git}/attributes"],
    "Git Config": ["*gitconfig", "**/{.git,.git/modules,.git/modules/*,git}/config"],
    "Git Ignore": ["*ignore", "**/{.git,git}/ignore", "**/.git/info/exclude"],
    "GitHub Actions": ["**/.github/workflows/*.{yml,yaml}"],
    "JSONC": ["*.json"],
    "Python constraints": ["*constraints*.txt"],
    "Python requirements": ["**/requirements/*.{in,txt}", "*requirements*.{in,txt}"],
    "SSH Config": ["**/ssh/config"]
  },
  "focus_follows_mouse": { "enabled": true, "debounce_ms": 100 },
  "git": { "inline_blame": { "show_commit_summary": true } },
  "git_panel": {
    "default_width": 320,
    "status_style": "label_color",
    "file_icons": true,
    "tree_view": true
  },
  "go_to_definition_scroll_strategy": "top",
  "icon_theme": { "dark": "Catppuccin Frappé", "light": "Catppuccin Latte", "mode": "system" },
  "inlay_hints": {
    "enabled": true,
    "show_background": true,
    "toggle_on_modifiers_press": { "control": true, "alt": true }
  },
  "inline_code_actions": false, // https://github.com/zed-industries/zed/issues/41563
  "languages": {
    "Fish": { "formatter": { "external": { "command": "fish_indent" } } },
    "Git Config": { "hard_tabs": true, "tab_size": 8 },
    "LOG": { "show_edit_predictions": false },
    "Plain Text": { "show_edit_predictions": false, "language_servers": [] },
    "Python": {
      "language_servers": ["ruff", "ty"],
      "code_actions_on_format": { "source.fixAll.ruff": true }
    },
    "Ruby": { "language_servers": ["ruby-lsp", "!solargraph"] }
  },
  "lsp": {
    "basedpyright": { "settings": { "basedpyright.analysis": { "diagnosticMode": "workspace" } } },
    "gopls": { "initialization_options": { "gofumpt": true } },
    "ruby-lsp": { "settings": { "use_bundler": false } },
    "ty": { "settings": { "diagnosticMode": "workspace" } },
    "yaml-language-server": { "settings": { "yaml": { "format": { "singleQuote": false } } } }
  },
  "minimum_contrast_for_highlights": 0,
  "preferred_line_length": 120,
  // https://github.com/zed-industries/zed/discussions/46827
  "project_panel": { "default_width": 320, "diagnostic_badges": true },
  "read_only_files": [
    // `detect_venv.directories`
    ".env/",
    ".venv/",
    "env/",
    "venv/",
    // basedpyright
    "~/Library/Application Support/Zed/languages/basedpyright/node_modules/basedpyright/dist/typeshed-fallback/",
    // ty
    "~/.cache/ty/vendored/typeshed/",
    // uv
    "~/.local/share/uv/python/"
  ],
  "seed_search_query_from_cursor": "selection",
  "show_signature_help_after_edits": true,
  "sticky_scroll": { "enabled": true },
  "tab_bar": { "show_pinned_tabs_in_separate_row": true },
  "tabs": { "git_status": true, "file_icons": true, "show_diagnostics": "all" },
  "telemetry": { "diagnostics": true, "metrics": true },
  "terminal": {
    "copy_on_select": true,
    "font_family": "FiraCode Nerd Font Mono",
    "minimum_contrast": 0,
    "working_directory": "current_file_directory"
  },
  "theme": { "dark": "Catppuccin Frappé", "light": "Catppuccin Latte", "mode": "system" },
  "title_bar": { "show_branch_status_icon": true },
  "toolbar": { "code_actions": true },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "use_smartcase_search": true,
  "which_key": { "enabled": true, "delay_ms": 500 },
  "zoomed_padding": false
}
