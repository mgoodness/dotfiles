#!/usr/bin/env bash
# shellcheck shell=bash

{{- $release := output "curl" "-fsSL" "https://api.github.com/repos/dmtrKovalenko/fff.nvim/releases/latest" | fromJson }}
{{- $version := trimPrefix "v" $release.tag_name }}

# fff-mcp version: {{ $version }}

if [ -n "${CI:-}" ]; then
    echo "Skipping due to $CI"
    exit
fi

_fff_current=$(fff-mcp --version 2>/dev/null | awk '{print $2}')
if [ "$_fff_current" != "{{ $version }}" ]; then
    echo "Updating fff-mcp (${_fff_current:-not installed} → {{ $version }})..."
    curl -fsLS https://dmtrkovalenko.dev/install-fff-mcp.sh | bash
fi

claude mcp get fff >/dev/null 2>&1 || claude mcp add -s user fff -- /Users/Michael.Goodness/.local/bin/fff-mcp
