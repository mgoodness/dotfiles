#!/usr/bin/env bash
# shellcheck shell=bash

if [ -n "${CI:-}" ]; then
    echo "Skipping due to \$CI"
    exit
fi

if ! command -v skl &>/dev/null; then
    echo "Skipping: skl not found"
    exit
fi

#
# Agent skills config hash: {{ .agentSkills | toJson | sha256sum }}

{{ range .agentSkills -}}
{{ $id := .id -}}
{{ if index . "skills" -}}
{{ range .skills -}}
skl add {{ $id }}/{{ . }} --agent claude-code,universal --global --yes
{{ end -}}
{{ else -}}
skl add {{ $id }} --agent claude-code,universal --global --yes
{{ end -}}
{{ end -}}
